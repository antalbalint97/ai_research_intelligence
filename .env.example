# =========================
# === MODEL CONFIG ========
# =========================

# Path to local GGUF model (mounted via volume)
LLM_MODEL_PATH=/app/models/qwen2.5-3b-instruct-q5_k_m.gguf
LLM_MODEL_PATH_FAST=/app/models/qwen2.5-3b-instruct-q5_k_m.gguf

# Threads (CPU)
LLM_N_THREADS=8

# =========================
# === FAST MODE ===========
# =========================

LLM_MAX_TOKENS_FAST=96
LLM_N_CTX_FAST=2048
LLM_CONTEXT_CHAR_LIMIT_FAST=3500

# =========================
# === FULL MODE ===========
# =========================

LLM_MAX_TOKENS_FULL=256
LLM_N_CTX_FULL=4096

# =========================
# === PIPELINE ============
# =========================

# Retrieval settings
FAST_RETRIEVAL_K=8
FAST_TOP_K=3
FULL_RETRIEVAL_K=20
FULL_TOP_K=5

# =========================
# === API =================
# =========================

API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# =========================
# === OPTIONAL ============
# =========================

# HuggingFace token (if needed for download)
HF_API_TOKEN=hf_YOUR_TOKEN_HERE
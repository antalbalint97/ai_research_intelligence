# =========================
# === MODEL CONFIG ========
# =========================

# Local mounted models
LLM_MODEL_PATH=/app/models/qwen2.5-3b-instruct-q5_k_m.gguf
LLM_MODEL_PATH_FAST=/app/models/qwen2.5-3b-instruct-q5_k_m.gguf
EMBEDDING_MODEL_NAME=/app/models/embeddings/all-MiniLM-L6-v2

# Threads (CPU)
LLM_N_THREADS=8

# Embedding runtime
EMBED_DEVICE=cpu
EMBED_NORMALIZE=true

# Offline / cache behavior
HF_HOME=/app/models/hf_cache
TRANSFORMERS_CACHE=/app/models/hf_cache
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# =========================
# === FAST MODE ===========
# =========================

LLM_MAX_TOKENS_FAST=96
LLM_N_CTX_FAST=2048
LLM_CONTEXT_CHAR_LIMIT_FAST=3500

# =========================
# === FULL MODE ===========
# =========================

LLM_MAX_TOKENS_FULL=256
LLM_N_CTX_FULL=4096

# =========================
# === PIPELINE ============
# =========================

FAST_RETRIEVAL_K=8
FAST_TOP_K=3
FULL_RETRIEVAL_K=20
FULL_TOP_K=5

# =========================
# === API =================
# =========================

API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# =========================
# === UI ==================
# =========================

API_BASE_URL=http://api:8000

# =========================
# === MODEL DOWNLOAD ======
# =========================

# Optional, only needed if the Qwen repo/file requires auth
HF_TOKEN=
QWEN_GGUF_REPO_ID=bartowski/Qwen2.5-3B-Instruct-GGUF
QWEN_GGUF_FILENAME=Qwen2.5-3B-Instruct-Q5_K_M.gguf
EMBEDDING_REPO_ID=sentence-transformers/all-MiniLM-L6-v2